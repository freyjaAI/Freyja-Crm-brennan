modules = ["nodejs-24"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  run = ["bash", "-c", "NODE_ENV=production node artifacts/freyja-crm/dist/index.cjs"]

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  