modules = ["nodejs-24"]

  [deployment]
  deploymentTarget = "autoscale"
  build = ["pnpm", "--filter", "rest-express", "run", "build"]
  run = ["node", "artifacts/freyja-crm/dist/index.cjs"]

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  