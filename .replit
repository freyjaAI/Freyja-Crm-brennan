modules = ["nodejs-24", "postgresql-16"]

  [deployment]
  deploymentTarget = "autoscale"
  build = ["pnpm", "install"]

[[ports]]
localPort = 8080
externalPort = 80

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "artifacts/freyja-crm: web"
  mode = "sequential"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "bash -c 'cd /home/runner/workspace/artifacts/freyja-crm && NODE_ENV=production node dist/index.cjs'"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

[nix]
channel = "stable-25_05"
  